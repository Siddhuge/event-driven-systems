# Git
.git/
.gitignore-local

# Node.js
node_modules/
npm-debug.log
yarn-error.log
package-lock.json.bak

# Environment
.env
.env.local
.env.*.local

# Terraform - LOCAL values containing secrets
# ⚠️ IMPORTANT: terraform.tfvars should be in gitignore
# Use terraform.tfvars.example as template, never commit tfvars
infra/envs/*/terraform.tfvars
infra/envs/*/.terraform/
infra/envs/*/tfplan
infra/envs/*/.terraform.lock.hcl
infra/envs/*/*.auto.tfvars
infra/envs/*/crash.log

# Local development
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Helm
helm/*/charts/
helm/*/.helmignore

# Kubernetes
kubeconfig
kubeconfig.local
kubeconfig-*.yaml
auth_token

# Azure
.azure/
azure-credentials.json
subscription-*
az-*.json
az-credentials-*.json

# Container
docker-compose.override.yml
Dockerfile.local

# CI/CD
.github/workflows/secrets.yml
.gitlab-ci.local.yml

# Credentials and secrets - NEVER COMMIT
**/secrets/**
**/*secret*
**/*token*
**/*password*
**/*credentials*
**/*apikey*
**/*api_key*
**/*private*
**/*key.pem*
**/*key.p8*
**/*key.pub*
**/*cert.pem*
**/*ca.pem*
.ssh/

