# ====================================================
# Development Environment Configuration
# ====================================================
#
# ⚠️ SECURITY WARNING:
# This file is a TEMPLATE ONLY. 
# Do NOT commit real SSH keys, passwords, or secrets to git.
#
# To use:
# 1. Copy this file: cp terraform.tfvars.example terraform.tfvars
# 2. Update values with your actual settings
# 3. Ensure terraform.tfvars is in .gitignore (already added)
# 4. Never commit terraform.tfvars to git
#
# Alternative: Use environment variables or Azure Pipelines
# TF_VAR_jumpbox_admin_ssh_public_key="ssh-rsa ..."
# TF_VAR_jumpbox_allowed_ssh_cidrs='["YOUR_IP/32"]'
# ====================================================

environment  = "dev"
location     = "Central India"
project_name = "event-driven"
created_date = "2026-04-29"

# ====================================================
# AKS Cluster Configuration
# ====================================================

# Keep cluster private to prevent internet exposure
aks_private_cluster_enabled             = true
aks_private_cluster_public_fqdn_enabled = true

# If making public (NOT RECOMMENDED), whitelist your IPs
aks_authorized_ips = [
  # "YOUR_OFFICE_IP/32",
  # "YOUR_HOME_IP/32"
]

# ====================================================
# Jumpbox Configuration (Optional)
# ====================================================
# Use jumpbox for secure SSH access to private AKS cluster
# Set jumpbox_enabled = true to create VM
# Then populate SSH key and CIDR below

jumpbox_enabled = false
jumpbox_admin_username = "azureuser"

# ⚠️ IMPORTANT: Generate SSH key locally, never share
# ssh-keygen -t rsa -b 4096 -f ~/.ssh/event-driven_rsa -N ""
# cat ~/.ssh/event-driven_rsa.pub

jumpbox_admin_ssh_public_key = "ssh-rsa AAAA..."  # Your actual public key from above

# Restrict SSH ONLY to your IP address
jumpbox_allowed_ssh_cidrs = [
  "YOUR_PUBLIC_IP/32"  # Get it: curl https://api.ipify.org
]

# ====================================================
# Key Vault Configuration
# ====================================================
# Keep public access enabled in dev for pipeline secrets setup
# Change to Deny in production

key_vault_public_network_access_enabled = true
key_vault_network_acls_default_action   = "Allow"
key_vault_network_acls_bypass           = "AzureServices"

# ====================================================
# Secrets Storage (NOT RECOMMENDED in tfvars)
# ====================================================
# Instead: Use Azure Pipelines variable groups or Key Vault directly
# See DEPLOYMENT_GUIDE.md for proper secret setup

key_vault_secrets = {}  # Leave empty, setup secrets manually via Azure CLI

# ====================================================
# Resource Tagging
# ====================================================
tags = {
  "Managed-By"  = "Terraform"
  "Cost-Center" = "Engineering"
  "Compliance"  = "SOC2"
  "Owner"       = "Platform-Team"
  "Backup"      = "true"
  "Environment" = "Development"
}
